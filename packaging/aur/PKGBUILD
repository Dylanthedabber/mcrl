pkgname=mcrl
pkgver=1.3.0
pkgrel=1
pkgdesc="Lift Minecraft's account chat restriction across every loader/version"
arch=('any')
url="https://github.com/Sm0keSkreen/mcrl"
license=('MIT')
depends=('java-runtime')
source=("mcrl.jar::https://github.com/Sm0keSkreen/mcrl/releases/download/v${pkgver}/mcrl.jar")
sha256sums=('5aef45822d86b2adf8ccfae1e01cb780bc22778e22d37b46a42a005f878ad9ad')
install=mcrl.install

package() {
    install -Dm644 "${srcdir}/mcrl.jar" "${pkgdir}/usr/share/mcrl/mcrl.jar"
}
