# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4
PortSystem          1.0

name                mcrl
version             1.3.0
categories          games
license              MIT
maintainers          {gh.com:Sm0keSkreen}
description          Lift Minecraft's account chat restriction across every loader/version
long_description    ${description}, applied globally via JDK_JAVA_OPTIONS so it works \
                     across vanilla and every loader (Fabric, Forge, Quilt, NeoForge) \
                     without per-instance setup.
homepage             https://github.com/Sm0keSkreen/mcrl

master_sites         https://github.com/Sm0keSkreen/mcrl/releases/download/v${version}/
distfiles            mcrl.jar
checksums            mcrl.jar sha256 5aef45822d86b2adf8ccfae1e01cb780bc22778e22d37b46a42a005f878ad9ad

supported_archs      noarch

use_configure        no

build {}

destroot {
    xinstall -m 755 -d ${destroot}${prefix}/share/mcrl
    xinstall -m 644 ${distpath}/mcrl.jar ${destroot}${prefix}/share/mcrl/mcrl.jar
}

post-activate {
    ui_msg "mcrl.jar is installed at ${prefix}/share/mcrl/mcrl.jar"
    ui_msg "One-time setup still needed: point JDK_JAVA_OPTIONS at that path (see the mcrl"
    ui_msg "README), or just run the full installer instead, which does that for you:"
    ui_msg "  curl -fsSL https://github.com/Sm0keSkreen/mcrl/releases/latest/download/install.sh | bash"
}
